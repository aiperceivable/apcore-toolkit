{
  "$schema": "https://apcore.dev/schemas/conformance-fixture.json",
  "title": "Display Overlay Resolution (§5.13)",
  "description": "Conformance tests for display overlay resolve priority chain. Each test case verifies that implementations correctly resolve alias, description, and documentation fields across the four-level priority chain: surface-specific > display default > binding-level > scanner-provided.",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "display_resolve_001",
      "description": "No binding entry — all display fields use scanner values",
      "input": {
        "scanned_module": {
          "module_id": "product.get_product.get",
          "description": "Get product by ID",
          "documentation": "Retrieves a product record from the database.",
          "tags": ["product"],
          "metadata": {}
        },
        "binding_map": {},
        "surface": "cli"
      },
      "expected": {
        "display": {
          "alias": "product.get_product.get",
          "description": "Get product by ID",
          "documentation": "Retrieves a product record from the database.",
          "tags": ["product"],
          "cli": {
            "alias": "product.get_product.get",
            "description": "Get product by ID"
          },
          "mcp": {
            "alias": "product_get_product_get",
            "description": "Get product by ID"
          },
          "a2a": {
            "alias": "product.get_product.get",
            "description": "Get product by ID"
          }
        }
      }
    },
    {
      "id": "display_resolve_002",
      "description": "Display alias only — all surfaces use display.alias",
      "input": {
        "scanned_module": {
          "module_id": "credit_purchase.get_purchase_status_by_payment_intent.get",
          "description": "Auto-generated description",
          "documentation": null,
          "tags": ["purchase"],
          "metadata": {}
        },
        "binding_map": {
          "credit_purchase.get_purchase_status_by_payment_intent.get": {
            "display": {
              "alias": "purchase-status"
            }
          }
        }
      },
      "expected": {
        "display": {
          "alias": "purchase-status",
          "description": "Auto-generated description",
          "documentation": null,
          "tags": ["purchase"],
          "cli": {
            "alias": "purchase-status",
            "description": "Auto-generated description"
          },
          "mcp": {
            "alias": "purchase-status",
            "description": "Auto-generated description"
          },
          "a2a": {
            "alias": "purchase-status",
            "description": "Auto-generated description"
          }
        }
      }
    },
    {
      "id": "display_resolve_003",
      "description": "Surface-specific override takes precedence over display default",
      "input": {
        "scanned_module": {
          "module_id": "order.create_order.post",
          "description": "Create a new order",
          "documentation": null,
          "tags": ["order"],
          "metadata": {}
        },
        "binding_map": {
          "order.create_order.post": {
            "display": {
              "alias": "create-order",
              "description": "Create a new order with validation",
              "cli": {
                "alias": "new-order",
                "description": "Create order"
              },
              "mcp": {
                "alias": "create_order"
              }
            }
          }
        }
      },
      "expected": {
        "display": {
          "alias": "create-order",
          "description": "Create a new order with validation",
          "cli": {
            "alias": "new-order",
            "description": "Create order"
          },
          "mcp": {
            "alias": "create_order",
            "description": "Create a new order with validation"
          },
          "a2a": {
            "alias": "create-order",
            "description": "Create a new order with validation"
          }
        }
      }
    },
    {
      "id": "display_resolve_004",
      "description": "Field-level sparsity — alias from scanner, description from overlay",
      "input": {
        "scanned_module": {
          "module_id": "user.get_profile.get",
          "description": "Get user profile endpoint",
          "documentation": "Original documentation from scanner",
          "tags": ["user"],
          "metadata": {}
        },
        "binding_map": {
          "user.get_profile.get": {
            "display": {
              "description": "Retrieve user profile by ID"
            }
          }
        }
      },
      "expected": {
        "display": {
          "alias": "user.get_profile.get",
          "description": "Retrieve user profile by ID",
          "documentation": "Original documentation from scanner",
          "tags": ["user"],
          "cli": {
            "alias": "user.get_profile.get",
            "description": "Retrieve user profile by ID"
          },
          "mcp": {
            "alias": "user_get_profile_get",
            "description": "Retrieve user profile by ID"
          },
          "a2a": {
            "alias": "user.get_profile.get",
            "description": "Retrieve user profile by ID"
          }
        }
      }
    },
    {
      "id": "display_resolve_005",
      "description": "suggested_alias in metadata — used as fallback when no binding alias",
      "input": {
        "scanned_module": {
          "module_id": "credit_purchase.get_purchase_status_by_payment_intent.get",
          "description": "Get purchase status",
          "documentation": null,
          "tags": ["purchase"],
          "metadata": {
            "suggested_alias": "purchase-status"
          }
        },
        "binding_map": {}
      },
      "expected": {
        "display": {
          "alias": "purchase-status",
          "description": "Get purchase status",
          "documentation": null,
          "tags": ["purchase"],
          "cli": {
            "alias": "purchase-status",
            "description": "Get purchase status"
          },
          "mcp": {
            "alias": "purchase-status",
            "description": "Get purchase status"
          },
          "a2a": {
            "alias": "purchase-status",
            "description": "Get purchase status"
          }
        }
      }
    },
    {
      "id": "display_resolve_006",
      "description": "Full chain — all levels populated, surface-specific wins",
      "input": {
        "scanned_module": {
          "module_id": "payment.charge.post",
          "description": "Scanner description",
          "documentation": "Scanner docs",
          "tags": ["scanner-tag"],
          "metadata": {
            "suggested_alias": "scanner-alias"
          }
        },
        "binding_map": {
          "payment.charge.post": {
            "description": "Binding description",
            "display": {
              "alias": "display-alias",
              "description": "Display description",
              "documentation": "Display docs",
              "tags": ["display-tag"],
              "cli": {
                "alias": "cli-alias",
                "description": "CLI description"
              },
              "mcp": {
                "alias": "mcp-alias",
                "description": "MCP description"
              },
              "a2a": {
                "alias": "A2A Alias",
                "description": "A2A description"
              }
            }
          }
        }
      },
      "expected": {
        "display": {
          "alias": "display-alias",
          "description": "Display description",
          "documentation": "Display docs",
          "tags": ["display-tag"],
          "cli": {
            "alias": "cli-alias",
            "description": "CLI description"
          },
          "mcp": {
            "alias": "mcp-alias",
            "description": "MCP description"
          },
          "a2a": {
            "alias": "A2A Alias",
            "description": "A2A description"
          }
        }
      }
    },
    {
      "id": "display_resolve_007",
      "description": "Binding-level description as fallback — display.description not set, binding.description wins over scanner",
      "input": {
        "scanned_module": {
          "module_id": "email.send.post",
          "description": "Scanner auto description",
          "documentation": null,
          "tags": [],
          "metadata": {}
        },
        "binding_map": {
          "email.send.post": {
            "description": "Binding-level description"
          }
        }
      },
      "expected": {
        "display": {
          "alias": "email.send.post",
          "description": "Binding-level description",
          "documentation": null,
          "tags": [],
          "cli": {
            "alias": "email.send.post",
            "description": "Binding-level description"
          },
          "mcp": {
            "alias": "email_send_post",
            "description": "Binding-level description"
          },
          "a2a": {
            "alias": "email.send.post",
            "description": "Binding-level description"
          }
        }
      }
    },
    {
      "id": "display_resolve_008",
      "description": "Display alias overrides suggested_alias",
      "input": {
        "scanned_module": {
          "module_id": "inventory.check_stock.get",
          "description": "Check stock",
          "documentation": null,
          "tags": [],
          "metadata": {
            "suggested_alias": "scanner-suggested"
          }
        },
        "binding_map": {
          "inventory.check_stock.get": {
            "display": {
              "alias": "check-stock"
            }
          }
        }
      },
      "expected": {
        "display": {
          "alias": "check-stock",
          "description": "Check stock",
          "cli": {
            "alias": "check-stock",
            "description": "Check stock"
          },
          "mcp": {
            "alias": "check-stock",
            "description": "Check stock"
          },
          "a2a": {
            "alias": "check-stock",
            "description": "Check stock"
          }
        }
      }
    },
    {
      "id": "display_resolve_009",
      "description": "Tags overlay — display.tags overrides binding and scanner tags",
      "input": {
        "scanned_module": {
          "module_id": "report.generate.post",
          "description": "Generate report",
          "documentation": null,
          "tags": ["scanner-tag-1", "scanner-tag-2"],
          "metadata": {}
        },
        "binding_map": {
          "report.generate.post": {
            "tags": ["binding-tag"],
            "display": {
              "tags": ["display-tag-1", "display-tag-2"]
            }
          }
        }
      },
      "expected": {
        "display": {
          "tags": ["display-tag-1", "display-tag-2"]
        }
      }
    },
    {
      "id": "display_resolve_010",
      "description": "Sparse overlay across 10 modules — only 2 have binding entries",
      "input": {
        "scanned_modules": [
          { "module_id": "mod_01", "description": "Module 1", "tags": [], "metadata": {} },
          { "module_id": "mod_02", "description": "Module 2", "tags": [], "metadata": {} },
          { "module_id": "mod_03", "description": "Module 3", "tags": [], "metadata": {} },
          { "module_id": "mod_04", "description": "Module 4", "tags": [], "metadata": {} },
          { "module_id": "mod_05", "description": "Module 5", "tags": [], "metadata": {} },
          { "module_id": "mod_06", "description": "Module 6", "tags": [], "metadata": {} },
          { "module_id": "mod_07", "description": "Module 7", "tags": [], "metadata": {} },
          { "module_id": "mod_08", "description": "Module 8", "tags": [], "metadata": {} },
          { "module_id": "mod_09", "description": "Module 9", "tags": [], "metadata": {} },
          { "module_id": "mod_10", "description": "Module 10", "tags": [], "metadata": {} }
        ],
        "binding_map": {
          "mod_03": {
            "display": {
              "alias": "three",
              "description": "Custom description for module 3"
            }
          },
          "mod_07": {
            "display": {
              "alias": "seven",
              "cli": { "alias": "lucky-seven" }
            }
          }
        }
      },
      "expected": {
        "results": [
          { "module_id": "mod_01", "display": { "alias": "mod_01", "description": "Module 1" } },
          { "module_id": "mod_02", "display": { "alias": "mod_02", "description": "Module 2" } },
          { "module_id": "mod_03", "display": { "alias": "three", "description": "Custom description for module 3" } },
          { "module_id": "mod_04", "display": { "alias": "mod_04", "description": "Module 4" } },
          { "module_id": "mod_05", "display": { "alias": "mod_05", "description": "Module 5" } },
          { "module_id": "mod_06", "display": { "alias": "mod_06", "description": "Module 6" } },
          { "module_id": "mod_07", "display": { "alias": "seven", "description": "Module 7", "cli": { "alias": "lucky-seven" } } },
          { "module_id": "mod_08", "display": { "alias": "mod_08", "description": "Module 8" } },
          { "module_id": "mod_09", "display": { "alias": "mod_09", "description": "Module 9" } },
          { "module_id": "mod_10", "display": { "alias": "mod_10", "description": "Module 10" } }
        ]
      }
    }
  ,
    {
      "id": "display_resolve_011",
      "description": "guidance resolves via priority chain: surface-specific > display.guidance > null",
      "input": {
        "scanned_module": {
          "module_id": "payment.charge.post",
          "description": "Charge payment",
          "documentation": null,
          "tags": [],
          "metadata": {}
        },
        "binding_map": {
          "payment.charge.post": {
            "display": {
              "guidance": "Use for one-time charges. Do NOT use for subscriptions.",
              "mcp": {
                "guidance": "Use for one-time charges. Do NOT use for subscriptions. Requires pre-authorization."
              }
            }
          }
        }
      },
      "expected": {
        "display": {
          "guidance": "Use for one-time charges. Do NOT use for subscriptions.",
          "cli": {
            "guidance": "Use for one-time charges. Do NOT use for subscriptions."
          },
          "mcp": {
            "guidance": "Use for one-time charges. Do NOT use for subscriptions. Requires pre-authorization."
          },
          "a2a": {
            "guidance": "Use for one-time charges. Do NOT use for subscriptions."
          }
        }
      }
    },
    {
      "id": "display_resolve_012",
      "description": "guidance is null when not authored — no scanner fallback",
      "input": {
        "scanned_module": {
          "module_id": "user.get_profile.get",
          "description": "Get user profile",
          "documentation": null,
          "tags": [],
          "metadata": {}
        },
        "binding_map": {}
      },
      "expected": {
        "display": {
          "guidance": null,
          "cli": { "guidance": null },
          "mcp": { "guidance": null },
          "a2a": { "guidance": null }
        }
      }
    },
    {
      "id": "display_resolve_013",
      "description": "MCP alias hard limit: alias >64 chars MUST be rejected with validation error",
      "input": {
        "scanned_module": {
          "module_id": "payment.charge.post",
          "description": "Charge payment",
          "tags": [],
          "metadata": {}
        },
        "binding_map": {
          "payment.charge.post": {
            "display": {
              "mcp": {
                "alias": "this_is_a_very_long_tool_name_that_exceeds_the_sixty_four_character_hard_limit"
              }
            }
          }
        }
      },
      "expected": {
        "error": "DISPLAY_ALIAS_INVALID",
        "surface": "mcp",
        "reason": "MCP alias exceeds 64-character hard limit"
      }
    },
    {
      "id": "display_resolve_014",
      "description": "CLI alias with spaces: SHOULD warn, fallback to display.alias",
      "input": {
        "scanned_module": {
          "module_id": "order.create.post",
          "description": "Create order",
          "tags": [],
          "metadata": {}
        },
        "binding_map": {
          "order.create.post": {
            "display": {
              "alias": "create-order",
              "cli": {
                "alias": "create order"
              }
            }
          }
        }
      },
      "expected": {
        "warning": "DISPLAY_ALIAS_INVALID",
        "surface": "cli",
        "display": {
          "cli": {
            "alias": "create-order"
          }
        }
      }
    }
  ]
}
